<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta charset="utf-8" />
    <title>Welcome to Craft CMS</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="referrer" content="origin-when-cross-origin" />
    <style>
        /**
         * Variables + Configuration
         */

        :root {
            --spacing-gutter: 25px;
            --spacing-thin: 16px;

            --color-text: hsl(209, 18%, 30%);
            --color-ground: hsl(200, 18%, 98%);
            --color-pane: hsl(212, 50%, 96%);
            --color-attn: hsl(203, 87%, 34%);
            --color-dull: hsl(211, 11%, 59%);
            --color-tint: hsl(200, 50%, 20%, 0.05);
        }

        /**
         * Base Styles
         */

        html,
        body {}

        body {
            background-color: var(--color-pane);
            color: var(--color-text);
            font-family: system-ui, BlinkMacSystemFont, -apple-system, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
            font-size: 16px;
            margin: 0;
            padding: 0;
        }

        h1 {
            margin-top: 0;
        }

        h2 {
            margin-top: 24px;
            font-size: 1em;
        }

        h2:first-child {
            margin-top: 0;
        }

        p {
            line-height: 1.5em;
            margin-bottom: 1em;
        }

        p:last-child {
            margin-bottom: 0;
        }

        ul {
            line-height: 1.3em;
            padding-left: 20px;
            margin-bottom: 0;
        }

        ul li {
            margin-bottom: 0.35em;
        }

        a {
            color: var(--color-attn);
        }

        a:hover {}

        .go {
            color: var(--color-attn);
        }

        .go:after {
            padding-left: 4px;
            content: '→';
            text-decoration: none !important;
        }

        small {
            color: var(--color-dull);
        }

        code {
            display: inline-block;
            color: #EF4E4E;
            padding: 2px 4px 1px 4px;
            background-color: var(--color-tint);
            border-radius: 3px;
            line-height: 1.3;
            font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, Courier, monospace;
            font-size: 0.85em;
        }

        /**
         * Page Regions
         */

        .background {
            background-image: url("{{ craftAsset('images/install/installer-bg.png') }}");
            background-position: center center;
            background-repeat: no-repeat;
            background-size: cover;
            padding-bottom: 50%;
        }

        #container {
            box-sizing: border-box;
            min-height: 100vh;
        }

        #modal {
            background: var(--color-ground);
            box-shadow: 0 25px 100px rgba(0, 0, 0, 0.5);
        }

        #main {}

        #aside {
            box-sizing: border-box;
            padding: var(--spacing-thin);
        }

        .content {
            padding: var(--spacing-gutter);
            padding-left: calc(var(--spacing-gutter) + env(safe-area-inset-left));
            padding-right: calc(var(--spacing-gutter) + env(safe-area-inset-right));
        }

        #aside .content {
            background: var(--color-pane);
        }

        #main .content {}

        #footer {
            border-top: 2px solid var(--color-tint);
            box-sizing: border-box;
            color: var(--color-dull);
            font-size: smaller;
            padding: var(--spacing-thin);
            width: 100%;
        }

        #footer ul {
            display: flex;
            list-style: none;
            justify-content: center;
            margin: 0;
            padding: 0;
        }

        #footer li {
            margin: 0;
            padding: 0;
        }

        #footer li:not(:last-child)::after {
            content: '/';
            margin: 0 1em;
            opacity: 0.25;
        }

        #footer a {
            color: inherit;
        }

        /**
         * Larger Clients
         */

        @media (min-width: 600px) {
            body {
                position: relative;
            }

            .background {
                /* This acts more like a full-screen background image at this scale... */
                height: 100%;
                left: 0;
                padding: 0;
                position: absolute;
                top: 0;
                width: 100%;
            }

            #container {
                align-items: center;
                display: flex;
                justify-content: center;
                padding: 25% var(--spacing-gutter) var(--spacing-gutter) var(--spacing-gutter);
                position: relative;
            }

            #modal {
                max-width: 800px;
                border-radius: 4px;
                overflow: auto;
            }
        }

        @media (min-width: 900px) {
            :root {
                --spacing-gutter: 35px;
            }

            #container {
                padding-top: var(--spacing-gutter);
            }

            #modal {
                display: flex;
                flex-wrap: wrap;
            }

            #main {
                width: 50%;
            }

            #aside {
                width: 50%;
            }
        }

        /**
         * Dark Mode
         */

        @media (prefers-color-scheme: dark) {
            :root {
                --color-text: hsl(214, 100%, 97%);
                --color-ground: hsl(222, 40%, 18%);
                --color-pane: hsl(222, 40%, 22%);
                --color-attn: hsl(225, 100%, 78%);
                --color-dull: hsl(211, 11%, 65%);
                --color-tint: hsl(200, 50%, 50%, 0.25);
            }
        }
    </style>
</head>
<body class="ltr">
<div class="background"></div>
<div id="container">
    <div id="modal">
        <div id="main">
            <div class="content">
                <h1>Welcome!</h1>
                <p>Thanks for installing Craft CMS.</p>
                <p>You’re looking at the <code>index.twig</code> template located in your <code>resources/views/</code> folder. Once you’re ready to start building out your site’s front end, you can replace this with something custom.</p>
                <p>If you’re new to Craft CMS, take a moment to explore some of the resources in the next panel&mdash;especially <a href="https://craftcms.com/discord" target="_blank">Discord</a> and <a href="https://craftcms.stackexchange.com/" target="_blank">Stack Exchange</a>. The Craft community is full of smart, friendly, and helpful people!</p>
                <p><span class="go"><a href="{{ cpUrl('') }}">Go to your control panel</a></span></p>
            </div>
        </div>
        <div id="aside">
            <div class="content">
                <h2>Popular Resources</h2>

                {% set resources = [
                    {
                        link: 'https://craftcms.com/docs/getting-started-tutorial/',
                        text: 'Tutorial',
                        description: 'Learn the basics',
                    },
                    {
                        link: 'https://craftcms.com/docs/5.x/',
                        text: 'Documentation',
                        description: 'Read the official docs',
                    },
                    {
                        link: 'https://craftcms.com/knowledge-base',
                        text: 'Knowledge Base',
                        description: 'Find answers to common problems',
                    },
                    {
                        link: 'https://craftcms.com/newsletter/subscribe',
                        text: 'Newsletter',
                        description: 'Get official news and community updates',
                    },
                    {
                        link: 'https://craftcms.com/events',
                        text: 'Events',
                        description: 'Meet our wonderful community',
                    },
                    {
                        link: 'https://craftcms.com/discord',
                        text: 'Discord',
                        description: 'Chat with other Craft developers',
                    },
                    {
                        link: 'https://craftcms.stackexchange.com/',
                        text: 'Stack Exchange',
                        description: 'Get help and help others',
                    },
                    {
                        link: 'https://craftquest.io/',
                        text: 'CraftQuest',
                        description: 'Unlimited video lessons and courses',
                    },
                ] %}

                <ul>
                    {% for resource in resources %}
                        <li>
                            <a href="{{ resource.link }}" target="_blank">{{ resource.text }}</a>
                            <br>
                            {% if resource.description %}
                                <small>{{ resource.description }}</small>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
        <div id="footer">
            <ul>
                <li>Craft CMS {{ craft.version }}</li>
                {% if currentUser %}
                    <li><a href="{{ cpUrl('users/me') }}">My Account</a></li>
                {% else %}
                    <li><a href="{{ cpUrl('login') }}">Log in</a></li>
                {% endif %}
            </ul>
        </div>
    </div>
</div>
</body>
</html>
