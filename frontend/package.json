{
    "name": "nuxt-app",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "nuxt build",
        "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 nuxt dev",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "check": "bun run lint && bun run format:check && bun run typecheck",
        "fix": "bun run format && bun run lint --fix",
        "typecheck": "nuxt typecheck",
        "codegen": "NODE_TLS_REJECT_UNAUTHORIZED=0 graphql-codegen"
    },
    "dependencies": {
        "@iconify-json/lucide": "^1.2.108",
        "@iconify-json/simple-icons": "^1.2.83",
        "@nuxt/image": "2.0.0",
        "@nuxt/ui": "^4.7.1",
        "@nuxtjs/seo": "5.1.3",
        "graphql": "^16.14.0",
        "nuxt": "^4.4.6",
        "tailwindcss": "^4.3.0"
    },
    "devDependencies": {
        "@graphql-codegen/cli": "^7.0.0",
        "@graphql-codegen/typed-document-node": "^7.0.0",
        "@graphql-codegen/typescript": "^6.0.1",
        "@graphql-codegen/typescript-operations": "^6.0.2",
        "@nuxt/eslint": "^1.15.2",
        "@types/node": "^25.9.1",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "vite-plugin-graphql-loader": "^5.1.1",
        "vue-tsc": "^3.3.0"
    },
    "packageManager": "bun@1.2.13"
}
